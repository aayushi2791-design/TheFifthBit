# HireReady Environment Variables
# Copy this to .env and fill in your values

PORT=5000
NODE_ENV=development

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/hireready

# JWT Secret (use a long random string in production)
JWT_SECRET=any_long_random_string_here_at_least_32_chars

# JWT Expiry
JWT_EXPIRE=7d

# Gemini API Key (Google AI Studio - Free)
GEMINI_API_KEY=AIzaSyDx4PyIGfWAvV4yovIx006z0j5Y02TkxuQ

# Anthropic API Key (optional, leave blank if using Gemini)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5000

# File upload limits (in bytes)
MAX_FILE_SIZE=5242880
